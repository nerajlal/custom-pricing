{% comment %}
  Theme App Extension - Global App Embed
  This "App Embed" enables the app globally on the storefront and provides visibility in the Theme Editor.
  It loads the necessary script tags via the Shopify App Proxy to ensure proper signature verification.
{% endcomment %}

{% schema %}
{
  "name": "Custom Pricing & Loyalty",
  "target": "body",
  "settings": [
    {
      "type": "paragraph",
      "content": "Enable this to show custom pricing and the loyalty widget on your storefront."
    }
  ]
}
{% endschema %}

<script>
  (function() {
    'use strict';
    
    const shop = "{{ shop.permanent_domain }}";
    const customerId = "{{ customer.id | default: '' }}";
    
    // Silence console logging for initialization unless manually debugging
    const log = (msg, isError) => {
        if (isError) console.warn('🔗 Metora: ' + msg);
        else if (window.location.search.includes('metora_debug')) console.log('🔗 Metora: ' + msg);
    };

    log('App Embed Initializing...');

    function injectScript(filename, id) {
      if (document.getElementById(id)) return;
      
      const storageKey = 'metora_proxy_path_' + filename;
      const cachedPath = localStorage.getItem(storageKey);
      
      // Paths to try in order of likelihood
      const pathsToTry = [
          cachedPath,                                // 0. Previously worked (if any)
          '/apps/custom-pricing/' + filename,        // 1. Standard Proxy
          '/apps/custom-pricing/app-proxy/' + filename,// 2. Nested Proxy
          '/script.js' === filename ? '/script.js' : null, // 3. Root mirror (if script.js)
          'https://custompricing.task19.com/app-proxy/' + filename // 4. Direct Fallback
      ].filter(Boolean);
      
      let attempt = 0;
      
      function tryNext() {
          if (attempt >= pathsToTry.length) return;
          
          let path = pathsToTry[attempt];
          const isFallback = path.startsWith('http');
          
          // Append required query params
          const separator = path.includes('?') ? '&' : '?';
          const src = path + separator + 'shop=' + shop + (customerId ? '&logged_in_customer_id=' + customerId : '');
          
          const script = document.createElement('script');
          script.async = true;
          script.src = src;
          
          script.onload = function() {
              if (!isFallback) {
                  localStorage.setItem(storageKey, path);
                  log('Successfully loaded ' + filename + ' via ' + path);
              }
          };
          
          script.onerror = function() {
              // Be silent on failures unless it's the very last fallback
              if (attempt === pathsToTry.length - 1) {
                  log('Failed to load ' + filename + ' even via fallback', true);
              }
              attempt++;
              tryNext();
          };
          
          document.head.appendChild(script);
      }
      
      tryNext();
    }

    // Inject scripts
    injectScript('script.js', 'metora-pricing-script');
    injectScript('loyalty-widget.js', 'metora-loyalty-widget');

  })();
</script>
