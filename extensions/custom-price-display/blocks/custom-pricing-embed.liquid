{% comment %}
  Theme App Extension - Global App Embed
  This "App Embed" enables the app globally on the storefront and provides visibility in the Theme Editor.
  It loads the necessary script tags via the Shopify App Proxy to ensure proper signature verification.
{% endcomment %}

{% schema %}
{
  "name": "Custom Pricing & Loyalty",
  "target": "body",
  "settings": [
    {
      "type": "paragraph",
      "content": "Enable this to show custom pricing and the loyalty widget on your storefront."
    }
  ]
}
{% endschema %}

<script>
  (function() {
    'use strict';
    
    // Shopify context
    const shop = "{{ shop.permanent_domain }}";
    const customerId = "{{ customer.id | default: '' }}";
    
    console.log('🔗 Custom Pricing & Loyalty: App Embed Initializing (v5)...');

    // Function to inject scripts via Proxy
    function injectScript(proxyPath, filename, id) {
      if (document.getElementById(id)) return;
      
      const script = document.createElement('script');
      script.id = id;
      script.async = true;
      
      // Attempt 1: Direct Proxy Path
      const primarySrc = proxyPath + '/' + filename + '?shop=' + shop + (customerId ? '&logged_in_customer_id=' + customerId : '');
      script.src = primarySrc;
      
      script.onload = function() {
        console.log('✅ Loaded: ' + filename + ' via Proxy');
      };
      
      script.onerror = function() {
        console.warn('⚠️ Proxy path failed for ' + filename + '. Using direct fallback...');
        const fallbackScript = document.createElement('script');
        fallbackScript.src = "https://custompricing.task19.com/app-proxy/" + filename + "?shop=" + shop + (customerId ? "&logged_in_customer_id=" + customerId : "");
        fallbackScript.id = id + '-fallback';
        document.head.appendChild(fallbackScript);
      };

      document.head.appendChild(script);
    }

    // List of likely proxy paths
    const proxyPaths = ['/apps/custom-pricing', '/apps/pricing', '/apps/custompicker', '/apps/pricing-app'];
    
    // Discovery: we'll try to find which proxy is working
    async function discoverProxy() {
      for (const path of proxyPaths) {
        try {
          const res = await fetch(path + '/ping?shop=' + shop);
          if (res.ok) {
             console.log('📍 Detected working Proxy path:', path);
             return path;
          }
        } catch(e) {}
      }
      return null;
    }

    async function init() {
      const workingPath = await discoverProxy() || proxyPaths[0];
      
      // Inject scripts
      injectScript(workingPath, 'script.js', 'metora-pricing-script');
      injectScript(workingPath, 'cart-script.js', 'metora-cart-script');
      injectScript(workingPath, 'loyalty-widget.js', 'metora-loyalty-widget');
      injectScript(workingPath, 'loyalty-cart.js', 'metora-loyalty-cart');
    }

    init();

  })();
</script>
