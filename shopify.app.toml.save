# Learn more about configuring your Shopify app at shopify.dev/docs/apps/tools/cli/configuration

name = "custom-price-neraj"
client_id = "90538"
application_url = "https://custompricing.task19.com"

[access_scopes]
# Learn more at https://shopify.dev/docs/apps/tools/cli/configuration#access_scopes
scopes = "read_customers,write_draft_orders,read_draft_orders,read_orders,read_products,write_discounts,write_price_rules,read_script_tags,write_script_tags"

[auth]
redirect_urls = [
  "https://custompricing.task19.com/auth/callback"
]

[webhooks]
api_version = "2025-10"

[pos]
embedded = false

[build]
automatically_update_urls_on_dev = true
